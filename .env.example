# ─────────────────────────────────────────────────────────────
# QuackCoin Platform — Environment Variables Reference
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env with real credentials.
# ─────────────────────────────────────────────────────────────

# ── DATABASE ─────────────────────────────────────────────────
# Format: mysql://<user>:<password>@<host>:<port>/<database>
# Pool: connection_limit=10 (max connections), pool_timeout=10 (seconds)
DATABASE_URL="mysql://quackcoin:changeme@localhost:3306/quackcoin?connection_limit=10&pool_timeout=10"

# ── AUTH (NextAuth) ───────────────────────────────────────────
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-generate-with-openssl-rand-base64-32"
# Development: http://localhost:3000 | Production: https://quackcoin.io
NEXTAUTH_URL="http://localhost:3000"
# Admin action confirmation secret (ban user, bulk actions)
# Generate: openssl rand -hex 16
ADMIN_CONFIRM_SECRET="change-me-hex-16-chars"

# ── APP ──────────────────────────────────────────────────────
# Public base URL (used in email links, OG images, cron callbacks)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── REDIS (Upstash) ──────────────────────────────────────────
# Create a free Redis database at: https://console.upstash.com
# Used for: session cache, SiteConfig cache, rate limiting, SSE presence, cron status cache
UPSTASH_REDIS_REST_URL="https://your-database.upstash.io"
UPSTASH_REDIS_REST_TOKEN="AxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA"

# ── RESEND (Transactional Email) ──────────────────────────────
# Create API key at: https://resend.com/api-keys
# Used for: invite codes, password reset, 2FA backup codes, notifications, cron failure alerts
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── SOLANA / USDC Payments ────────────────────────────────────
# Webhook HMAC secret — generate: openssl rand -base64 32
SOLANA_WEBHOOK_SECRET="changeme-at-least-32-chars"
# Your Solana wallet public key that receives USDC payments
SOLANA_RECIPIENT_ADDRESS="YourSolanaPublicKeyHere"
# Solana RPC endpoint (mainnet default, or use Helius/QuickNode for production)
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# USDC SPL token mint address on Solana mainnet (standard address)
USDC_MINT_ADDRESS="EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v"

# ── VAPID (Web Push Notifications) ────────────────────────────
# Generate keypair: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URI identifying your application
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:admin@quackcoin.io"

# ── CRON ──────────────────────────────────────────────────────
# Secret passed in Authorization header by the PM2 cron process
# Generate: openssl rand -base64 48
# Must be at least 32 characters. Store the same value in both Next.js and cron process envs.
CRON_SECRET="changeme-generate-with-openssl-rand-base64-48"

# ── HUBSPOT CRM (Optional) ────────────────────────────────────
# Obtain from: https://app.hubspot.com/private-apps
# If absent, HubSpot contact sync is silently disabled.
# HUBSPOT_API_KEY=""
# HUBSPOT_LEADS_LIST_ID=""

# ── AFFILIATE WEBHOOK (Optional) ──────────────────────────────
# HMAC secret for verifying affiliate network webhook payloads.
# If absent, the affiliate webhook endpoint returns 503.
# AFFILIATE_WEBHOOK_SECRET=""

# ── SENTRY (Optional) ─────────────────────────────────────────
# Error monitoring. If absent, Sentry is silently disabled.
# Obtain from: https://sentry.io/settings/<org>/projects/<project>/keys/
# SENTRY_DSN=""

# ── LOGGING ───────────────────────────────────────────────────
# Log level for pino logger. Default: info
# Options: trace | debug | info | warn | error | fatal
# LOG_LEVEL="info"
